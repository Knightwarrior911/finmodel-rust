{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "finmodel",
  "version": "0.9.15",
  "identifier": "com.finmodel.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "finmodel — Financial Model Builder",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "license": "LicenseRef-Proprietary",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwNTVFNEVBM0M3QTIxOEMKUldTTUlYbzg2dVJWOEc5UmN0YzFxUzJFTzJZR2FyZHhtUDRLVDY5SG9xMyt3eUpXcys4L2NZT1EK",
      "endpoints": [
        "https://github.com/Knightwarrior911/finmodel-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
